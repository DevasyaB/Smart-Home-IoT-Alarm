#include <ESP8266WiFi.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1 
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

#define FLAME_PIN D5
#define BUZZER_PIN D6
#define IR_PIN D7

bool dangerDetected = false;
bool intruderBeepState = false; 
unsigned long lastCloudUpdate = 0; 

const char* ssid = "YOUR_WIFI_NAME";           
const char* password = "YOUR_WIFI_PASSWORD";   
const char* host = "api.thingspeak.com";
String writeAPIKey = "YOUR_THINGSPEAK_API_KEY"; 

void setup() {
  Serial.begin(115200);
  
  pinMode(FLAME_PIN, INPUT);
  pinMode(IR_PIN, INPUT);
  pinMode(BUZZER_PIN, INPUT); 

  Wire.begin(D2, D1); 
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED failed to initialize");
    for(;;);
  }
  
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 10);
  display.println("Connecting Wi-Fi...");
  display.display();

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  
  display.clearDisplay();
  display.setCursor(0, 10);
  display.println("Wi-Fi Connected!");
  display.display();
  delay(2000);
}

void loop() {
  int flameValue = digitalRead(FLAME_PIN); 
  int irValue = digitalRead(IR_PIN);
  
  bool isFire = (flameValue == LOW);
  bool isIntruder = (irValue == LOW);

  if (isFire) { 
    dangerDetected = true;
    pinMode(BUZZER_PIN, OUTPUT);
    digitalWrite(BUZZER_PIN, LOW); 
  } else if (isIntruder) {
    dangerDetected = true;
    intruderBeepState = !intruderBeepState; 
    
    if (intruderBeepState) {
      pinMode(BUZZER_PIN, OUTPUT);
      digitalWrite(BUZZER_PIN, LOW); 
    } else {
      pinMode(BUZZER_PIN, INPUT);    
    }
  } else {
    dangerDetected = false;
    pinMode(BUZZER_PIN, INPUT);    
  }

  updateDisplay(isFire, isIntruder);

  if (dangerDetected) {
    if (millis() - lastCloudUpdate > 15000) {
      sendToThingSpeak(isFire, isIntruder);
      lastCloudUpdate = millis(); 
    }
  }
  
  delay(150); 
}

void updateDisplay(bool isFire, bool isIntruder) {
  display.clearDisplay();
  
  display.setCursor(0, 0);
  display.setTextSize(1);
  display.println("Home Security System");
  display.drawLine(0, 10, 128, 10, SSD1306_WHITE);

  display.setCursor(0, 15);
  display.print("Fire: ");
  display.print(isFire ? "DETECTED!" : "Safe");
  
  display.setCursor(0, 30);
  display.print("Motion: ");
  display.print(isIntruder ? "DETECTED!" : "Clear");

  display.setCursor(0, 50);
  if (dangerDetected) {
    display.print("STATUS: DANGER!");
  } else {
    display.print("STATUS: SECURE");
  }
  
  display.display();
}

void sendToThingSpeak(bool isFire, bool isIntruder) {
  WiFiClient client;
  if (!client.connect(host, 80)) {
    Serial.println("Connection failed");
    return;
  }
  
  int fireData = isFire ? 1 : 0;
  int intruderData = isIntruder ? 1 : 0;
  
  String url = "/update?api_key=" + writeAPIKey + "&field1=" + String(fireData) + "&field2=" + String(intruderData);
  
  client.print(String("GET ") + url + " HTTP/1.1\r\n" +
               "Host: " + host + "\r\n" +
               "Connection: close\r\n\r\n");
  delay(500); 
}
